notification:
  bark_key: ""
  serverchan_key: ""

# === 猫眼 ===
maoyan:
  device_id: ""          # ADB 设备号，空则禁用
  viewer_name: ""        # 观演人姓名
  sale_time: "2026-04-01 10:00:00"
  concert_name: "演唱会名称"
  price: 1280
  # 盲点模式坐标（可选，通过 python tools/maoyan_calibrate.py 获取）
  # price_btn: [540, 800]
  # viewer_btn: [540, 1200]
  # submit_btn: [540, 1600]

# === 大麦 ===
damai:
  device_id: ""          # ADB 设备号，空则禁用
  sale_time: "2026-04-01 10:00:00"
  concert_name: "演唱会名称"
  price: 1280
  # 坐标通过 python tools/damai_calibrate.py 校准
  buy_btn: [1600, 2650]
  confirm_btn: [920, 2500]

# === 票星球 ===
piaoxingqiu:
  access_token: ""       # 通过 python tools/pxq_login.py 获取
  refresh_token: ""
  phone: ""
  sale_time: "2026-04-01 12:00:00"
  concert_name: "演唱会名称"
  price: 380
  show_id: ""            # 通过 python tools/pxq_show.py 获取
  session_id: ""
  seat_plan_id: ""
  concurrent_requests: 10

# === 淘宝购物车 ===
# device_id 通过 ADB_DEVICES 环境变量指定，优先读取；
# 空则从上方各平台配置中自动推断；均无则尝试第一个在线设备。
taobao:
  device_id: ""
  sale_time: "2026-04-01 12:00:00"
  concert_name: "演唱会名称"
  # 通过 python tools/taobao_calibrate.py 获取各按钮坐标
  checkout_btn: [1655, 2628]
  pay_btn: [918, 2743]
  # 开售时段（每日多场）
  daily_times: ["14:00:00", "20:00:00"]
  tap_lead_ms: 55        # 提前多少毫秒开始发 tap
  tap_burst: 30          # 到点后连续发多少次
  tap_gap_ms: 8          # 每次间隔（ms）
  max_seconds: 12       # 最多冲多少秒
